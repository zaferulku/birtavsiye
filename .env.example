# birtavsiye.net — Environment Variables Template
# Kopyala: cp .env.example .env.local
# Gerçek değerleri Vercel Project Settings veya local'de doldur.

# ═══ Supabase (zorunlu) ═══
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SERVER ONLY — asla client'a/Github'a sızdırma
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ═══ NextAuth (Google OAuth) ═══
NEXTAUTH_URL=http://localhost:3000
# Üret: openssl rand -base64 32
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ═══ Cron + Internal API (gateway secrets) ═══
# Üret: openssl rand -hex 32
CRON_SECRET=
INTERNAL_API_SECRET=

# ═══ AI Providers (chatbot intent + classifier) ═══
# Multi-provider fallback: Gemini → Groq → NVIDIA
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
# Opsiyonel — generate-category-keywords.mjs için tercih
# LLM_PROVIDER=nvidia

# ═══ External enrichment (opsiyonel) ═══
ICECAT_USERNAME=
ICECAT_PASSWORD=
SCRAPER_API_KEY=
UNSPLASH_ACCESS_KEY=

# ═══ Scrape toggles (opsiyonel, script flag'leri) ═══
# CRON_SCRAPE_DISABLED=1   # cron tetiklemesini atla
# SKIP_24H=0                # MM scrape'te 24h fresh skip'i bypass
# SKIP_PHONE=1              # PttAVM rotation'da telefon kategorisini atla
# MM_DELAY_MS=350           # MM scrape rate-limit (ms per request)
# ONLY_DB_SLUG=akilli-telefon  # MM tek kategori filter

# ═══ Site toggles ═══
# MAINTENANCE_MODE=true    # site bakım modu (src/proxy.ts:5)
