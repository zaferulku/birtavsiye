{
  "name": "birtavsiye",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "backup": "git add src scripts public .claude/agents && git diff --cached --quiet || git commit -m \"backup: $(node -e \"console.log(new Date().toISOString().slice(0,16).replace('T',' '))\")\"",
    "undo": "git reset --soft HEAD~1",
    "history": "git log --oneline -20",
    "status": "git status --short",
    "eval:chatbot": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_200.jsonl",
    "eval:chatbot:dryrun": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_200.jsonl --limit 5",
    "eval:chatbot:scenario": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_200.jsonl --scenario",
    "eval:chatbot:category": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_200.jsonl --category",
    "eval:chatbot:2": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_eval2_200.jsonl",
    "eval:chatbot:2:dryrun": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_eval2_200.jsonl --limit 5",
    "eval:chatbot:2:scenario": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_eval2_200.jsonl --scenario",
    "eval:chatbot:2:category": "node scripts/eval-chatbot-dialogs.mjs --input tests/chatbot/fixtures/chatbot_dialogs_eval2_200.jsonl --category",
    "generate:chatbot:ecommerce-intent": "node scripts/generate-chatbot-ecommerce-intent-scenarios.cjs",
    "test:chatbot:intent": "node tests/chatbot/run-ecommerceIntentRules.cjs",
    "fix:pttavm-categories": "node --experimental-strip-types --env-file=.env.local scripts/fix-pttavm-category-paths.mts",
    "cleanup:pttavm-product-categories": "node --env-file=.env.local scripts/cleanup-pttavm-product-name-categories.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "cheerio": "^1.2.0",
    "js-yaml": "^4.1.1",
    "next": "16.2.0",
    "next-auth": "^4.24.13",
    "node-fetch": "^3.3.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
